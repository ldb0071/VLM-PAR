class NegativePromptCache:
    """Manages a cache of negative prompts"""
    
    def __init__(self, cache_path="negative_prompt_cache.json"):
        self.cache_path = cache_path
        self.cache = self._load_cache()
    
    def _load_cache(self):
        """Load the cache of previously generated prompts"""
        if os.path.exists(self.cache_path):
            try:
                with open(self.cache_path, "r") as f:
                    return json.load(f)
            except (json.JSONDecodeError, IOError):
                print(f"Warning: Could not load cache from {self.cache_path}, creating new cache")
        return {}
    
    def _save_cache(self):
        """Save the cache to disk"""
        try:
            with open(self.cache_path, "w") as f:
                json.dump(self.cache, f)
        except IOError:
            print(f"Warning: Could not save cache to {self.cache_path}")
    
    def get(self, key, attribute=None):
        """Get a negative prompt from the cache"""
        cache_key = f"{key}_{attribute}" if attribute else key
        return self.cache.get(cache_key)
    
    def set(self, key, value, attribute=None):
        """Set a negative prompt in the cache"""
        cache_key = f"{key}_{attribute}" if attribute else key
        self.cache[cache_key] = value
        self._save_cache()

class SoftPromptEmbeddings(nn.Module):
    """Learnable soft prompt embeddings for prefix tuning"""
    
    def __init__(self, hidden_size, prefix_length=10, num_attributes=None):
        super().__init__()
        self.hidden_size = hidden_size
        self.prefix_length = prefix_length
        
        if num_attributes is not None:
            # Create attribute-specific soft prompts with contiguous memory layout
            self.soft_prompts = nn.ParameterDict({
                f"attr_{i}": nn.Parameter(torch.randn(1, prefix_length, hidden_size).contiguous() * 0.02)
                for i in range(num_attributes)
            })
        else:
            # Create a single shared soft prompt with contiguous memory layout
            self.soft_prompts = nn.Parameter(torch.randn(1, prefix_length, hidden_size).contiguous() * 0.02)
    
    def forward(self, text_embeddings, attribute_idx=None):
        """
        Prepend soft prompts to text embeddings
        
        Args:
            text_embeddings: Text embeddings [batch_size, seq_len, hidden_size]
            attribute_idx: Optional attribute index for attribute-specific prompts
            
        Returns:
            Enhanced text embeddings with soft prompts prepended
        """
        batch_size = text_embeddings.shape[0]
        
        if hasattr(self.soft_prompts, 'keys'):
            # Using attribute-specific prompts
            if attribute_idx is None:
                raise ValueError("attribute_idx must be provided when using attribute-specific prompts")
            
            prompt_key = f"attr_{attribute_idx}"
            if prompt_key not in self.soft_prompts:
                raise ValueError(f"No soft prompt found for attribute index {attribute_idx}")
            
            soft_prompt = self.soft_prompts[prompt_key]
        else:
            # Using shared prompt
            soft_prompt = self.soft_prompts
        
        # Expand to batch size and ensure contiguous memory layout
        soft_prompt_expanded = soft_prompt.expand(batch_size, -1, -1).contiguous()
        
        # Concatenate soft prompt with text embeddings
        return torch.cat([soft_prompt_expanded, text_embeddings], dim=1)

class EnhancedCrossAttention(nn.Module):
    """Cross-attention mechanism with contrastive learning between positive and negative prompts"""
    
    def __init__(self, hidden_size, num_heads=8, dropout=0.1):
        super().__init__()
        self.hidden_size = hidden_size
        self.num_heads = num_heads
        
        # Multi-head attention for positive and negative cross-attention
        self.pos_attention = nn.MultiheadAttention(
            embed_dim=hidden_size,
            num_heads=num_heads,
            dropout=dropout,
            batch_first=True
        )
        
        self.neg_attention = nn.MultiheadAttention(
            embed_dim=hidden_size,
            num_heads=num_heads,
            dropout=dropout,
            batch_first=True
        )
        
        # Learnable weight for negative attention subtraction
        self.neg_weight = nn.Parameter(torch.tensor(0.5))
        
        # Feature projection layers
        self.image_proj = nn.Linear(hidden_size, hidden_size)
        self.pos_text_proj = nn.Linear(hidden_size, hidden_size)
        self.neg_text_proj = nn.Linear(hidden_size, hidden_size)
        
        # Output projection
        self.output_proj = nn.Linear(hidden_size, hidden_size)
    
    def forward(self, image_features, pos_text_features, neg_text_features=None):
        """
        Apply enhanced cross-attention with negative prompts
        
        Args:
            image_features: Image features [batch, seq_len, hidden]
            pos_text_features: Positive text features [batch, seq_len, hidden]
            neg_text_features: Optional negative text features [batch, seq_len, hidden]
            
        Returns:
            Enhanced feature representation
        """
        batch_size = image_features.shape[0]
        
        # Project features
        image_proj = self.image_proj(image_features)
        pos_text_proj = self.pos_text_proj(pos_text_features)
        
        # Handle shape mismatches by ensuring consistent dimensions
        # Check and fix batch size mismatch
        if pos_text_proj.shape[0] == 1 and image_proj.shape[0] > 1:
            pos_text_proj = pos_text_proj.expand(batch_size, -1, -1)
            
        # Ensure sequence length dimensions are compatible
        # For attention to work properly, we need to ensure that the key and value 
        # have the same sequence length dimension
        if pos_text_features.shape[1] != pos_text_proj.shape[1]:
            # Pad or truncate as needed
            min_seq_len = min(pos_text_features.shape[1], pos_text_proj.shape[1])
            pos_text_proj = pos_text_proj[:, :min_seq_len, :]
        
        # Check if hidden dimensions match
        if image_proj.shape[2] != self.hidden_size or pos_text_proj.shape[2] != self.hidden_size:
            raise ValueError(f"Hidden dimension mismatch: image_proj={image_proj.shape}, pos_text_proj={pos_text_proj.shape}, expected hidden_size={self.hidden_size}")
            
        # Debug shapes
        # print(f"image_proj: {image_proj.shape}, pos_text_proj: {pos_text_proj.shape}")
            
        try:
            # Positive attention
            pos_attended, _ = self.pos_attention(
                query=image_proj,
                key=pos_text_proj,
                value=pos_text_proj
            )
        except RuntimeError as e:
            # If there's still an error, try reshaping to ensure compatibility with attention mechanism
            # This is a fallback solution
            head_dim = self.hidden_size // self.num_heads
            
            # Reshape for multi-head attention
            q = image_proj.view(batch_size, -1, self.num_heads, head_dim).transpose(1, 2)
            k = pos_text_proj.view(batch_size, -1, self.num_heads, head_dim).transpose(1, 2)
            v = pos_text_proj.view(batch_size, -1, self.num_heads, head_dim).transpose(1, 2)
            
            # Perform attention manually
            scores = torch.matmul(q, k.transpose(-2, -1)) / (head_dim ** 0.5)
            attn_weights = F.softmax(scores, dim=-1)
            pos_attended = torch.matmul(attn_weights, v)
            pos_attended = pos_attended.transpose(1, 2).contiguous().view(batch_size, -1, self.hidden_size)
        
        # Apply negative attention if provided
        if neg_text_features is not None:
            neg_text_proj = self.neg_text_proj(neg_text_features)
            
            # Ensure batch size matches
            if neg_text_proj.shape[0] == 1 and image_proj.shape[0] > 1:
                neg_text_proj = neg_text_proj.expand(batch_size, -1, -1)
                
            # Handle sequence length mismatch
            if neg_text_features.shape[1] != neg_text_proj.shape[1]:
                min_seq_len = min(neg_text_features.shape[1], neg_text_proj.shape[1])
                neg_text_proj = neg_text_proj[:, :min_seq_len, :]
            
            try:
                # Negative attention
                neg_attended, _ = self.neg_attention(
                    query=image_proj,
                    key=neg_text_proj,
                    value=neg_text_proj
                )
            except RuntimeError:
                # Fallback solution
                head_dim = self.hidden_size // self.num_heads
                
                # Reshape for multi-head attention
                q = image_proj.view(batch_size, -1, self.num_heads, head_dim).transpose(1, 2)
                k = neg_text_proj.view(batch_size, -1, self.num_heads, head_dim).transpose(1, 2)
                v = neg_text_proj.view(batch_size, -1, self.num_heads, head_dim).transpose(1, 2)
                
                # Perform attention manually
                scores = torch.matmul(q, k.transpose(-2, -1)) / (head_dim ** 0.5)
                attn_weights = F.softmax(scores, dim=-1)
                neg_attended = torch.matmul(attn_weights, v)
                neg_attended = neg_attended.transpose(1, 2).contiguous().view(batch_size, -1, self.hidden_size)
            
            # Subtract negative attention with learnable weight
            attended_features = pos_attended - self.neg_weight * neg_attended
        else:
            attended_features = pos_attended
        
        # Final projection
        return self.output_proj(attended_features)

class ContrastiveLoss(nn.Module):
    """Contrastive loss for aligning positive samples and pushing away negative samples"""
    
    def __init__(self, temperature=0.07, margin=0.2):
        super().__init__()
        self.temperature = temperature
        self.margin = margin
    
    def forward(self, image_features, pos_features, neg_features=None):
        """
        Compute contrastive loss with positive and negative samples
        
        Args:
            image_features: Image features [batch, hidden]
            pos_features: Positive text features [batch, hidden]
            neg_features: Negative text features [batch, hidden]
            
        Returns:
            Contrastive loss value
        """
        # Normalize features
        image_features = F.normalize(image_features, dim=-1)
        pos_features = F.normalize(pos_features, dim=-1)
        
        # Positive similarity
        pos_sim = torch.sum(image_features * pos_features, dim=-1)
        
        if neg_features is not None:
            # Normalize negative features
            neg_features = F.normalize(neg_features, dim=-1)
            
            # Negative similarity
            neg_sim = torch.sum(image_features * neg_features, dim=-1)
            
            # Triplet-style contrastive loss with margin
            loss = torch.clamp(neg_sim - pos_sim + self.margin, min=0.0)
            
            return loss.mean()
        else:
            # If no negative features, just maximize positive similarity
            return -pos_sim.mean()

