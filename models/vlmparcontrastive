    def __init__(self, 
                 model_name, 
                 num_classes_dict, 
                 questions=None,
                 neg_questions=None,
                 use_soft_prompts=True,
                 soft_prompt_length=10,
                 use_negative_prompts=True,
                 contrastive_weight=0.5,
                 temperature=0.07,
                 margin=0.2,
                 use_focal_loss=False,
                 focal_alpha=0.25,
                 focal_gamma=2.0,
                 use_label_smoothing=False,
                 smoothing=0.1):
        super().__init__()
        
        # Initialize base model and tokenizer
        self.vlm_base = AutoModel.from_pretrained(model_name)
        self.tokenizer = AutoTokenizer.from_pretrained(model_name)
        self.num_classes_dict = num_classes_dict
        self.hidden_size = self.vlm_base.vision_model.config.hidden_size
        
        # Initialize questions
        self.questions = questions if questions is not None else self.DEFAULT_QUESTIONS
        self.neg_questions = neg_questions if neg_questions is not None else self.DEFAULT_NEG_QUESTIONS
        
        # Validate questions
        for key in num_classes_dict.keys():
            if key not in self.questions:
                raise ValueError(f"Key '{key}' in num_classes_dict has no corresponding question.")
            if key not in self.neg_questions:
                print(f"Warning: No negative question for '{key}'. Using default negative.")
                self.neg_questions[key] = f"The person does not have {key.replace('_', ' ')}."
        
        # Initialize negative prompt cache
        self.negative_cache = NegativePromptCache()
        
        # Store negative prompts configuration
        self.use_negative_prompts = use_negative_prompts
        
        # Initialize soft prompt embeddings if enabled
        self.use_soft_prompts = use_soft_prompts
        if use_soft_prompts:
            self.soft_prompts = SoftPromptEmbeddings(
                hidden_size=self.hidden_size,
                prefix_length=soft_prompt_length,
                num_attributes=len(num_classes_dict)
            )
        
        # Initialize enhanced cross-attention
        self.cross_attention = EnhancedCrossAttention(
            hidden_size=self.hidden_size,
            num_heads=8,
            dropout=0.1
        )
        
        # Initialize contrastive loss
        self.contrastive_loss_fn = ContrastiveLoss(
            temperature=temperature,
            margin=margin
        )
        self.contrastive_weight = contrastive_weight
        
        # Initialize classification loss
        self.use_focal_loss = False  # Explicitly set to False
        self.use_label_smoothing = False  # Explicitly set to False
        
        # Use standard CrossEntropyLoss regardless of parameters
        self.classification_loss = nn.CrossEntropyLoss()
        
        # Initialize classifier heads
        self.classifier_heads = nn.ModuleDict({
            key: nn.Linear(self.hidden_size, num_labels)
            for key, num_labels in num_classes_dict.items()
        })

    def _process_text(self, question, device, attribute_idx=None):
        """Process text input with optional soft prompts"""
        # Tokenize the question
        text_inputs = self.tokenizer(question, return_tensors="pt", padding=True)
        text_inputs = {k: v.to(device) for k, v in text_inputs.items()}
        
        # Get text embeddings
        text_outputs = self.vlm_base.text_model(**text_inputs)
        text_seq = text_outputs.last_hidden_state
        text_pooled = text_outputs.pooler_output
        
        # Apply soft prompts if enabled
        if self.use_soft_prompts:
            text_seq = self.soft_prompts(text_seq, attribute_idx)
        
        return text_seq, text_pooled

    def forward(self, pixel_values, question_type=None, return_dict=True, labels=None):
        device = pixel_values.device
        
        # Process image
        vision_outputs = self.vlm_base.vision_model(pixel_values=pixel_values)
        image_seq = vision_outputs.last_hidden_state
        image_pooled = vision_outputs.pooler_output
        
        # Process single attribute or all attributes
        if question_type is not None and question_type != 'all':
            return self._forward_single_attribute(
                image_seq=image_seq,
                image_pooled=image_pooled,
                question_type=question_type,
                device=device,
                return_dict=return_dict,
                labels=labels
            )
        else:
            return self._forward_all_attributes(
                image_seq=image_seq,
                image_pooled=image_pooled,
                device=device,
                return_dict=return_dict,
                labels=labels
            )

    def _forward_single_attribute(self, image_seq, image_pooled, question_type, device, return_dict, labels=None):
        """Process a single attribute"""
        # Validate question type
        if question_type not in self.questions:
            raise ValueError(f"Invalid question type. Must be one of {list(self.questions.keys())}")
        
        # Get attribute index
        attr_idx = list(self.questions.keys()).index(question_type)
        
        # Get positive and negative questions
        pos_question = self.questions[question_type]
        neg_question = self.neg_questions[question_type]
        
        # Process positive text
        pos_text_seq, pos_text_pooled = self._process_text(pos_question, device, attr_idx)
        
        # Process negative text only if using negative prompts
        neg_text_seq, neg_text_pooled = None, None
        if self.use_negative_prompts:
            neg_text_seq, neg_text_pooled = self._process_text(neg_question, device, attr_idx)
        
        # Apply cross-attention
        attended_features = self.cross_attention(
            image_features=image_seq,
            pos_text_features=pos_text_seq,
            neg_text_features=neg_text_seq if self.use_negative_prompts else None
        )
        
        # Get CLS token features
        features = attended_features[:, 0, :]
        
        # Calculate cosine similarities
        pos_similarity = F.cosine_similarity(features, pos_text_seq[:, 0, :], dim=-1)
        neg_similarity = torch.zeros_like(pos_similarity)
        
        # Calculate negative similarity and contrastive score only if using negative prompts
        if self.use_negative_prompts and neg_text_seq is not None:
            neg_similarity = F.cosine_similarity(features, neg_text_seq[:, 0, :], dim=-1)
            # Calculate contrastive score (positive - negative)
            contrastive_score = pos_similarity - neg_similarity
        else:
            # Without negative prompts, contrastive score is just positive similarity
            contrastive_score = pos_similarity
        
        # Get classification logits
        logits = self.classifier_heads[question_type](features)
        probs = F.softmax(logits, dim=-1)
        pred = torch.argmax(probs, dim=-1)
        
        # Calculate loss if labels provided
        loss = None
        if labels is not None:
            # Standard cross entropy loss
            cls_loss = self.classification_loss(logits, labels[question_type])
            
            # Contrastive loss
            if self.use_negative_prompts and neg_text_seq is not None:
                cont_loss = self.contrastive_loss_fn(
                    image_features=features,
                    pos_features=pos_text_seq[:, 0, :],
                    neg_features=neg_text_seq[:, 0, :]
                )
            else:
                # Only positive features when negative prompts are disabled
                cont_loss = self.contrastive_loss_fn(
                    image_features=features,
                    pos_features=pos_text_seq[:, 0, :],
                    neg_features=None
                )
            
            # Combined loss (cross entropy + contrastive)
            loss = cls_loss + self.contrastive_weight * cont_loss
        
        # Generate human-readable answers
        answers = self._generate_answers(question_type, pred)
        
        if return_dict:
            result = {
                "answer": answers,
                "pos_similarity": pos_similarity.tolist(),
                "neg_similarity": neg_similarity.tolist(),
                "contrastive_score": contrastive_score.tolist(),
                "confidence": torch.max(probs, dim=-1)[0].tolist(),
                "logits": logits,
                "probs": probs
            }
            if loss is not None:
                result["loss"] = loss
            return result
        
        return answers

    def _forward_all_attributes(self, image_seq, image_pooled, device, return_dict, labels=None):
        """Process all attributes"""
        answers = {}
        total_loss = 0.0
        
        for idx, (key, question) in enumerate(self.questions.items()):
            # Get positive and negative questions
            pos_question = question
            neg_question = self.neg_questions[key]
            
            # Process positive text
            pos_text_seq, pos_text_pooled = self._process_text(pos_question, device, idx)
            
            # Process negative text only if using negative prompts
            neg_text_seq, neg_text_pooled = None, None
            if self.use_negative_prompts:
                neg_text_seq, neg_text_pooled = self._process_text(neg_question, device, idx)
            
            # Apply cross-attention
            attended_features = self.cross_attention(
                image_features=image_seq,
                pos_text_features=pos_text_seq,
                neg_text_features=neg_text_seq if self.use_negative_prompts else None
            )
            
            # Get CLS token features
            features = attended_features[:, 0, :]
            
            # Calculate cosine similarities
            pos_similarity = F.cosine_similarity(features, pos_text_seq[:, 0, :], dim=-1)
            neg_similarity = torch.zeros_like(pos_similarity)
            
            # Calculate negative similarity and contrastive score only if using negative prompts
            if self.use_negative_prompts and neg_text_seq is not None:
                neg_similarity = F.cosine_similarity(features, neg_text_seq[:, 0, :], dim=-1)
                # Calculate contrastive score (positive - negative)
                contrastive_score = pos_similarity - neg_similarity
            else:
                # Without negative prompts, contrastive score is just positive similarity
                contrastive_score = pos_similarity
            
            # Get classification logits
            logits = self.classifier_heads[key](features)
            probs = F.softmax(logits, dim=-1)
            pred = torch.argmax(probs, dim=-1)
            
            # Calculate loss if labels provided
            if labels is not None and key in labels:
                # Standard cross entropy loss
                cls_loss = self.classification_loss(logits, labels[key])
                
                # Contrastive loss
                if self.use_negative_prompts and neg_text_seq is not None:
                    cont_loss = self.contrastive_loss_fn(
                        image_features=features,
                        pos_features=pos_text_seq[:, 0, :],
                        neg_features=neg_text_seq[:, 0, :]
                    )
                else:
                    # Only positive features when negative prompts are disabled
                    cont_loss = self.contrastive_loss_fn(
                        image_features=features,
                        pos_features=pos_text_seq[:, 0, :],
                        neg_features=None
                    )
                
                # Add to total loss (cross entropy + contrastive)
                attr_loss = cls_loss + self.contrastive_weight * cont_loss
                total_loss += attr_loss
            
            # Generate human-readable answers
            attr_answers = self._generate_answers(key, pred)
            
            # Store results
            answers[key] = {
                "answer": attr_answers,
                "pos_similarity": pos_similarity.tolist(),
                "neg_similarity": neg_similarity.tolist(),
                "contrastive_score": contrastive_score.tolist(),
                "confidence": torch.max(probs, dim=-1)[0].tolist(),
                "logits": logits,
                "probs": probs
            }
        
        if return_dict:
            if labels is not None:
                answers["loss"] = total_loss
            return answers
        else:
            return " ".join([v["answer"][0] for v in answers.values()])

    def _generate_answers(self, question_type, pred):
        """Generate human-readable answers based on predictions"""
        if question_type == 'gender':
            return [f"The person is {'female' if p.item() == 1 else 'male'}." for p in pred]
        elif question_type in ['hat', 'glasses', 'hand_bag', 'shoulder_bag', 'backpack', 'hold_objects_in_front',
                              'short_sleeve', 'long_sleeve', 'upper_stride', 'upper_logo', 'upper_plaid',
                              'upper_splice', 'lower_stripe', 'lower_pattern', 'long_coat', 'trousers',
                              'shorts', 'skirt_dress', 'boots']:
            return [f"{'Yes' if p.item() == 1 else 'No'}, the person {'is' if p.item() == 1 else 'is not'} {question_type.replace('_', ' ')}." for p in pred]
        else:
            num_classes = self.num_classes_dict[question_type]
            if num_classes == 2:
                return [f"{'Yes' if p.item() == 1 else 'No'}, the person {'is' if p.item() == 1 else 'is not'} {question_type.replace('_', ' ')}." for p in pred]
            else:
                return [f"The person's {question_type.replace('_', ' ')} is {self._get_class_name(question_type, p.item())}." for p in pred]

    def _get_class_name(self, key, class_idx):
        """Map class index to class name for multi-class attributes"""
        class_names = {
            'age': ['young', 'teenager', 'adult', 'old']
        }
        return class_names.get(key, [f"class_{i}" for i in range(self.num_classes_dict[key])])[class_idx]
    
    def prepare_for_training(self):
        """Prepare the model for training"""
        print("Preparing model for training...")
        return {"status": "ready"}
    
    def predict(self, pixel_values, question_type=None):
        """Make predictions with the model"""
        with torch.no_grad():
            outputs = self.forward(pixel_values, question_type=question_type, return_dict=True)
            
            if question_type is not None and question_type != 'all':
                # Single attribute prediction
                logits = outputs["logits"]
                pred = torch.argmax(logits, dim=-1).cpu().numpy()[0]
                
                if question_type == 'gender':
                    class_name = 'female' if pred == 1 else 'male'
                else:
                    class_name = 'yes' if pred == 1 else 'no'
                
                return {question_type: int(pred)}, {question_type: class_name}
            else:
                # All attributes prediction
                classes_idx = {}
                classes = {}
                
                for key in outputs.keys():
                    if key == "loss":
                        continue
                        
                    logits = outputs[key]["logits"]
                    pred = torch.argmax(logits, dim=-1).cpu().numpy()[0]
                    classes_idx[key] = int(pred)
                    
                    if key == 'gender':
                        classes[key] = 'female' if pred == 1 else 'male'
                    else:
                        classes[key] = 'yes' if pred == 1 else 'no'
                
                return classes_idx, classes
    
    def load_model(self, model_path):
        """Load model weights from checkpoint"""
        weights = torch.load(model_path)["model_state_dict"]
        new_weights = {}
        for key, value in weights.items():
            new_key = key.replace("module.", "")
            new_weights[new_key] = value
        self.load_state_dict(new_weights) 